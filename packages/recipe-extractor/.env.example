# --- Required -----------------------------------------------------------------

# Any OpenAI-compatible vision chat-completions endpoint. OpenRouter by default;
# get a key at https://openrouter.ai/keys. (RECIPE_LLM_API_KEY is accepted too.)
OPENROUTER_API_KEY=

# --- LLM (optional overrides) -------------------------------------------------

# Vision model used to read the frames. Must support image input.
RECIPE_MODEL=google/gemini-2.5-flash
# Override the endpoint if you're not on OpenRouter (e.g. point at OpenAI/Groq).
# RECIPE_LLM_URL=https://openrouter.ai/api/v1/chat/completions
# Per-image detail sent to the model. "low" is cheap and plenty for recipes.
RECIPE_IMAGE_DETAIL=low

# --- Frame sampling (optional) ------------------------------------------------

RECIPE_FRAME_CAP=20          # max frames sent to the LLM
RECIPE_FRAME_FLOOR=6         # min frames (top up uniformly if scene cuts are sparse)
RECIPE_SCENE_THRESHOLD=0.3   # ffmpeg scene-change sensitivity (lower = more frames)

# --- Output / storage ---------------------------------------------------------

# Where downloaded MP4s, thumbnails and per-run artifacts are written.
RECIPE_OUTPUT_DIR=recipe_output

# --- Optional: remote video host (instead of local disk) ----------------------
# If set, extracted MP4s are rsync'd to this host and NOT kept locally. The
# value is an scp-style destination rooted at a write-only rrsync command, e.g.
# "recipe@your-host:". Pair with RECIPE_VIDEO_BASE_URL on your read side.
# RECIPE_VIDEO_UPLOAD_SSH=
# RECIPE_VIDEO_UPLOAD_SSH_KEY=        # inline private key (PEM)
# RECIPE_VIDEO_BASE_URL=https://cdn.example.com/recipe-mp4

# --- Optional: proxy for yt-dlp (geo / rate-limit relief) ---------------------
# Easiest: a full proxy URL.
# RECIPE_PROXY_URL=http://user:pass@host:port
# Or assemble from parts (Webshare-style rotating residential proxies):
# PROXY_USERNAME=
# PROXY_PASSWORD=
# PROXY_HOST=p.webshare.io
# PROXY_PORT=80
# PROXY_COUNTRY=                       # optional 2-letter code prefix

# --- Optional: yt-dlp cookies (login/age-gated clips) -------------------------
# RECIPE_YTDLP_COOKIES_BROWSER=chrome

# --- Optional: Instagram Messages API "share a reel to us" flow ---------------
# Only needed if you connect the inbound webhook so people can SHARE reels into
# your Instagram DM inbox (see instagram_webhook.py / make_router).
#
# Graph API token for the IG Business / Page that receives the DMs. Also used to
# resolve shared reels to public URLs and to send DM replies.
# INSTAGRAM_PAGE_ACCESS_TOKEN=
# Your chosen verify token — must match the value you enter in the Meta webhook
# config (the GET handshake echoes hub.challenge only when these match).
# INSTAGRAM_VERIFY_TOKEN=
# Meta app secret — used to verify the X-Hub-Signature-256 HMAC on every POST.
# Leave unset in local dev to skip the check; ALWAYS set it in production.
# INSTAGRAM_APP_SECRET=
# IG user id — only needed to send replies when using an EAAB (Facebook) token.
# INSTAGRAM_BUSINESS_ID=

# --- Optional: HTTP service ---------------------------------------------------
# RECIPE_SERVICE_HOST=127.0.0.1
# RECIPE_SERVICE_PORT=8000
